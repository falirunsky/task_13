<UserControl x:Class="task_12.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Padding="24">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock Text="{Binding AppName}"    FontSize="22" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
        <TextBlock Text="{Binding Version}"    FontSize="14" Foreground="Gray"
                   HorizontalAlignment="Center" Margin="0,0,0,16"/>
        <TextBlock Text="{Binding Description}" TextWrapping="Wrap"
                   MaxWidth="460" TextAlignment="Center" Margin="0,0,0,16"/>
        <Separator Margin="0,0,0,16"/>
        <TextBlock HorizontalAlignment="Center">
            <Run Text="Автор: "       FontWeight="SemiBold"/><Run Text="{Binding Author}"/>
        </TextBlock>
        <TextBlock HorizontalAlignment="Center" Margin="0,6,0,0">
            <Run Text="Технологии: "  FontWeight="SemiBold"/><Run Text="{Binding Technology}"/>
        </TextBlock>
    </StackPanel>
</UserControl>
