<UserControl x:Class="task_12.Views.ContactEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Padding="24">
    <StackPanel MaxWidth="480" VerticalAlignment="Center" HorizontalAlignment="Center">

        <TextBlock Text="Редактирование контакта"
                   FontSize="18" FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Имя -->
            <Label Grid.Row="0" Grid.Column="0"
                   Content="Имя:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="0" Grid.Column="1"
                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>

            <!-- Телефон -->
            <Label Grid.Row="2" Grid.Column="0"
                   Content="Телефон:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="2" Grid.Column="1"
                     Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
        </Grid>

        <!-- Индикатор сохранения -->
        <TextBlock Text="Сохранение..."
                   Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                   Foreground="Gray" Margin="0,0,0,8"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Отмена"
                    Command="{Binding CancelCommand}"
                    Width="90" Margin="0,0,8,0"/>
            <Button Content="Сохранить"
                    Command="{Binding SaveCommand}"
                    Width="90"
                    IsDefault="True"/>
        </StackPanel>

    </StackPanel>
</UserControl>
