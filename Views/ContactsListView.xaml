<UserControl x:Class="task_12.Views.ContactsListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Padding="12">
    <StackPanel>
        <TextBlock Text="Телефонная книга" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

        <!-- Индикатор загрузки из БД -->
        <TextBlock Text="Загрузка из базы данных..."
                   Visibility="{Binding IsLoading,
                       Converter={StaticResource BoolToVisibilityConverter}}"
                   Foreground="Gray" Margin="0,0,0,8"/>

        <GroupBox Header="Новый контакт" Padding="8" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>
                <Label Content="Имя:"     VerticalAlignment="Center" Grid.Column="0"/>
                <TextBox Grid.Column="1"  Margin="4,0"
                         Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Телефон:" VerticalAlignment="Center" Grid.Column="2"/>
                <TextBox Grid.Column="3"  Margin="4,0"
                         Text="{Binding NewPhone, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="4"   Content="Добавить" Margin="4,0,0,0"
                        Command="{Binding AddCommand}"/>
            </Grid>
        </GroupBox>

        <DataGrid ItemsSource="{Binding Contacts}"
                  SelectedItem="{Binding SelectedContact}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  Height="260">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id"      Binding="{Binding Id}"    Width="50"/>
                <DataGridTextColumn Header="Имя"     Binding="{Binding Name}"  Width="*"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="*"/>
                <DataGridTemplateColumn Header="Действия" Width="170">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Изменить"
                                        Width="76"
                                        Margin="0,1,4,1"
                                        CommandParameter="{Binding}"
                                        Command="{Binding DataContext.EditCommand,
                                            RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                <Button Content="Удалить"
                                        Width="76"
                                        Margin="0,1,0,1"
                                        CommandParameter="{Binding}"
                                        Command="{Binding DataContext.DeleteCommand,
                                            RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </StackPanel>
</UserControl>
